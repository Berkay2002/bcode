{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // .tool_response.filePath') && bunx oxfmt --write \"$FILE\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Formatting with oxfmt..."
          }
        ]
      }
    ]
  }
}
